# --- Cluster ---
NAMESPACE=redbank-demo

# --- LLM (required — OpenAI-compatible endpoint, e.g. vLLM) ---
OPENAI_API_KEY=
LLM_BASE_URL=https://your-vllm-or-openai.example.com/v1
LLM_MODEL=your-model-id

# --- Keycloak admin (required for setup-keycloak / cleanup) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_PASSWORD=
# KEYCLOAK_URL auto-detected from 'oc get route keycloak -n keycloak' if not set
# KEYCLOAK_HOST is derived from KEYCLOAK_URL; override only if the MCP JWKS host differs
# KEYCLOAK_HOST=keycloak-keycloak.apps.example.com

# --- PGVector credentials (for MCP server pgvector-credentials secret) ---
PGVECTOR_USER=app
PGVECTOR_PASSWORD=app

# --- Playground ---
# Auto-derived as http://redbank-orchestrator.<NAMESPACE>.svc:8080 if not set.
# ORCHESTRATOR_URL=http://redbank-orchestrator.redbank-demo.svc:8080

# Keycloak OIDC (optional — when all three are set the playground requires login)
# KEYCLOAK_URL=https://keycloak.example.com
# KEYCLOAK_REALM=redbank
# KEYCLOAK_CLIENT_ID=redbank-mcp

# --- MLflow tracing (optional — auto-detected from cluster if not set) ---
# MLFLOW_TRACKING_URI=
